{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiveforge.local/specs/config/project-registry.schema.json",
  "title": "HiveForge project registry",
  "description": "Canonical schema for registered projects HiveForge may deploy. local-git and http-git are development/internal Git tooling, not the managed service release deployment contract.",
  "type": "object",
  "additionalProperties": false,
  "required": ["projects"],
  "properties": {
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "source", "repository", "approvedRefs"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "enum": ["github", "local-git", "http-git"]
          },
          "repository": {
            "type": "string",
            "minLength": 1
          },
          "approvedRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "source": { "const": "github" } },
              "required": ["source"]
            },
            "then": {
              "properties": {
                "repository": {
                  "type": "string",
                  "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\\.git$"
                }
              }
            }
          },
          {
            "if": {
              "properties": { "source": { "const": "http-git" } },
              "required": ["source"]
            },
            "then": {
              "properties": {
                "repository": {
                  "type": "string",
                  "pattern": "^http://((10|127)\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})|169\\.254\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})|172\\.(1[6-9]|2[0-9]|3[0-1])\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})|192\\.168\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})|localhost|[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?|(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)+local)(:[0-9]+)?/.+\\.git$"
                }
              }
            }
          },
          {
            "if": {
              "properties": { "source": { "const": "local-git" } },
              "required": ["source"]
            },
            "then": {
              "properties": {
                "repository": {
                  "type": "string",
                  "pattern": "^file:///.+"
                }
              }
            }
          }
        ]
      }
    }
  }
}
