{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiveforge.local/specs/config/environments.schema.json",
  "title": "HiveForge environments",
  "description": "Canonical schema for known deployment environments.",
  "type": "object",
  "additionalProperties": false,
  "required": ["current", "environments"],
  "properties": {
    "current": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "kind", "capabilities", "policy"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["local-docker", "docker", "swarm"]
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["docker", "compose", "swarm", "volumes", "secrets", "registry"]
            },
            "uniqueItems": true
          },
          "policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["projects"],
            "properties": {
              "projects": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "actions"],
                  "properties": {
                    "id": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9-]*$"
                    },
                    "profiles": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9-]*$"
                      },
                      "uniqueItems": true
                    },
                    "actions": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "enum": ["deploy", "remove", "purge", "update", "upgrade"]
                      },
                      "uniqueItems": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
