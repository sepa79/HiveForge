{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiveforge.local/specs/config/environments.schema.json",
  "title": "HiveForge environments",
  "description": "Canonical schema for known deployment environments.",
  "type": "object",
  "additionalProperties": false,
  "required": ["current", "environments"],
  "properties": {
    "current": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "kind", "capabilities", "policy"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["local-docker", "docker", "swarm"]
          },
          "capabilities": {
            "type": "object",
            "additionalProperties": false,
            "required": ["runtime", "managedRoot"],
            "properties": {
              "runtime": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": ["docker-single", "docker-swarm"]
                },
                "uniqueItems": true
              },
              "managedRoot": {
                "type": "object",
                "additionalProperties": false,
                "required": ["shared"],
                "properties": {
                  "shared": {
                    "type": "boolean"
                  },
                  "nodes": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^[A-Za-z0-9_.-]+$"
                    },
                    "uniqueItems": true
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "properties": { "shared": { "const": false } },
                      "required": ["shared"]
                    },
                    "then": {
                      "required": ["nodes"],
                      "properties": {
                        "nodes": {
                          "type": "array",
                          "minItems": 1
                        }
                      }
                    }
                  }
                ]
              },
              "placement": {
                "type": "boolean"
              }
            }
          },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "hostname", "role", "availability", "status", "labels"],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "hostname": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9_.-]+$"
                },
                "role": {
                  "type": "string",
                  "enum": ["manager", "worker"]
                },
                "availability": {
                  "type": "string",
                  "enum": ["active", "pause", "drain"]
                },
                "status": {
                  "type": "string",
                  "minLength": 1
                },
                "labels": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "vars": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "pattern": "^[a-z][A-Za-z0-9]*(\\.[a-z][A-Za-z0-9]*)+$"
            },
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            }
          },
          "policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["projects"],
            "properties": {
              "projects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "actions"],
                  "properties": {
                    "id": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9-]*$"
                    },
                    "profiles": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9-]*$"
                      },
                      "uniqueItems": true
                    },
                    "actions": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "enum": ["deploy", "remove", "purge", "update", "upgrade"]
                      },
                      "uniqueItems": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
