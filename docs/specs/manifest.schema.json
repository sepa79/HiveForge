{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiveforge.local/specs/manifest.schema.json",
  "title": "HiveForge manifest",
  "description": "Canonical schema for root and component hiveforge.yaml manifests.",
  "oneOf": [
    { "$ref": "#/$defs/rootManifest" },
    { "$ref": "#/$defs/componentManifest" }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "runtimeCapability": {
      "type": "string",
      "enum": ["docker-single", "docker-swarm"]
    },
    "profileCapabilityName": {
      "type": "string",
      "enum": ["placement"]
    },
    "variableName": {
      "type": "string",
      "pattern": "^[a-z][A-Za-z0-9]*(\\.[a-z][A-Za-z0-9]*)+$"
    },
    "vars": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/variableName" },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "profileRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "managedRoot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "shared"],
          "properties": {
            "required": { "const": true },
            "shared": { "type": "boolean" },
            "node": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+$"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": { "shared": { "const": false } },
                "required": ["shared"]
              },
              "then": {
                "required": ["node"],
                "properties": {
                  "node": {
                    "type": "string"
                  }
                }
              }
            },
            {
              "if": {
                "properties": { "shared": { "const": true } },
                "required": ["shared"]
              },
              "then": {
                "properties": {
                  "node": true
                },
                "not": {
                  "required": ["node"]
                }
              }
            }
          ]
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/profileCapabilityName" },
          "uniqueItems": true
        }
      }
    },
    "projectProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "runtime", "serviceSet"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "runtime": { "$ref": "#/$defs/runtimeCapability" },
        "serviceSet": { "$ref": "#/$defs/identifier" },
        "requires": { "$ref": "#/$defs/profileRequirements" }
      }
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "(^|/)\\.\\.(/|$)" }
        ]
      }
    },
    "lifecycleActionDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["playbook"],
      "properties": {
        "playbook": { "$ref": "#/$defs/relativePath" }
      }
    },
    "managedPathDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "target", "mode"],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "source": { "$ref": "#/$defs/relativePath" },
        "target": { "$ref": "#/$defs/relativePath" },
        "mode": { "const": "replace" }
      }
    },
    "rootManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "version", "project", "components"],
      "properties": {
        "kind": { "const": "project" },
        "version": {
          "type": "string",
          "const": "0.5"
        },
        "project": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "repository", "actions"],
          "properties": {
            "name": { "$ref": "#/$defs/identifier" },
            "repository": {
              "type": "string",
              "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\\.git$"
            },
            "actions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/lifecycleActionName" },
              "uniqueItems": true
            },
            "profiles": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/projectProfile" },
              "uniqueItems": true
            },
            "vars": {
              "$ref": "#/$defs/vars"
            }
          }
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "manifest"],
            "properties": {
              "name": { "$ref": "#/$defs/identifier" },
              "manifest": { "$ref": "#/$defs/relativePath" }
            }
          }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "managedPaths": {
              "type": "array",
              "items": { "$ref": "#/$defs/managedPathDeclaration" },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "componentManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "component", "deployment"],
      "properties": {
        "kind": { "const": "component" },
        "component": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "project"],
          "properties": {
            "name": { "$ref": "#/$defs/identifier" },
            "project": { "$ref": "#/$defs/identifier" }
          }
        },
        "deployment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["adapter", "actions"],
          "properties": {
            "adapter": { "const": "ansible" },
            "actions": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": false,
              "properties": {
                "deploy": { "$ref": "#/$defs/lifecycleActionDeclaration" },
                "remove": { "$ref": "#/$defs/lifecycleActionDeclaration" },
                "purge": { "$ref": "#/$defs/lifecycleActionDeclaration" },
                "update": { "$ref": "#/$defs/lifecycleActionDeclaration" },
                "upgrade": { "$ref": "#/$defs/lifecycleActionDeclaration" }
              }
            }
          }
        },
        "requirements": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "volumes": {
              "type": "array",
              "items": { "$ref": "#/$defs/identifier" },
              "uniqueItems": true
            },
            "secrets": {
              "type": "array",
              "items": { "$ref": "#/$defs/identifier" },
              "uniqueItems": true
            },
            "environment": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]*$"
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "lifecycleActionName": {
      "type": "string",
      "enum": ["deploy", "remove", "purge", "update", "upgrade"]
    }
  }
}
